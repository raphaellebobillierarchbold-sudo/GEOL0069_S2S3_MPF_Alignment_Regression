# Large raw data files
data/raw/*.npz
data/raw/*.npy
data/raw/*.zip
*.SAFE/
*.tif
*.tiff
*.nc
*.h5
*.hdf5

# Processed generated data files
data/processed/*.npz
data/processed/*.npy
data/processed/*.csv

# Large trained model files stored externally / regenerated by notebooks
models/*.joblib
models/*.keras

# Keep documentation files
!data/raw/README_data.md
!data/processed/README_processed.md
!models/README_models.md

# Python and notebook clutter
__pycache__/
.ipynb_checkpoints/
.DS_Store
